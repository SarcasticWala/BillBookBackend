NODE_ENV=development
PORT=5000

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173

# Comma-separated phone numbers (E.164, e.g. +919800054895) granted admin access
ADMIN_PHONES=

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/billbook

# JWT — backend-issued session tokens
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=7d

# Firebase Admin (verifies the client's Firebase ID token at login)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cloudinary (item image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
