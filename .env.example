NODE_ENV=development
PORT=5000

# Comma-separated allowed frontend origins for CORS.
# Include your live frontend URL in production, e.g.:
# https://bill-book-frontend.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Comma-separated phone numbers (E.164, e.g. +919800054895) granted admin access
ADMIN_PHONES=

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/billbook

# JWT — backend-issued session tokens
JWT_SECRET=your-long-random-secret
JWT_EXPIRES_IN=7d

# --- Email (OTP delivery) ---
# Preferred: Brevo HTTPS API (one API key, no OAuth, works on Render).
# Sign up free at brevo.com, verify SMTP_FROM as a sender, create an API key.
BREVO_API_KEY=
# Alternative: Gmail API over HTTPS (OAuth2) — also works on Render.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Sender address (your Gmail) — used as the "From" for Gmail API and SMTP.
SMTP_FROM=youraddress@gmail.com
# Fallback for LOCAL dev only (Gmail app password). SMTP is blocked on Render.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Cloudinary (item image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Firebase is no longer used for auth (email/password + backend email OTP).
# These are optional and can be omitted.
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
